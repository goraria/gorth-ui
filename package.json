{
  "name": "gorth-ui",
  "version": "0.1.0",
  "description": "Shared shadcn-based UI package",
  "type": "module",
  "author": "Gorthenburg",
  "license": "GORTH",
  "private": true,
  "keywords": [
    "gorth",
    "shadcn",
    "ui",
    "react"
  ],
  "main": "./.ui/index.cjs",
  "module": "./.ui/index.js",
  "types": "./.ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./.ui/index.d.ts",
      "import": "./.ui/index.js",
      "require": "./.ui/index.cjs"
    },
    "./lib/*": {
      "types": "./.ui/lib/*.d.ts",
      "import": "./.ui/lib/*.js",
      "require": "./.ui/lib/*.cjs"
    },
    "./ui/*": {
      "types": "./.ui/components/ui/*.d.ts",
      "import": "./.ui/components/ui/*.js",
      "require": "./.ui/components/ui/*.cjs"
    },
    "./io/*": {
      "types": "./.ui/components/io/*.d.ts",
      "import": "./.ui/components/io/*.js",
      "require": "./.ui/components/io/*.cjs"
    },
    "./layout/*": {
      "types": "./.ui/components/layout/*.d.ts",
      "import": "./.ui/components/layout/*.js",
      "require": "./.ui/components/layout/*.cjs"
    },
    "./background/*": {
      "types": "./.ui/components/background/*.d.ts",
      "import": "./.ui/components/background/*.js",
      "require": "./.ui/components/background/*.cjs"
    },
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs"
  },
  "files": [
    ".ui",
    "src/styles/globals.css",
    "postcss.config.mjs"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/components/*/*.tsx src/hooks/*.ts src/hooks/*.tsx src/lib/*.ts --format esm,cjs --dts --out-dir .ui --clean",
    "dev": "tsup src/index.ts src/components/*/*.tsx src/hooks/*.ts src/hooks/*.tsx src/lib/*.ts --format esm,cjs --dts --out-dir .ui --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "update": "pnpm update",
    "shadcn": "pnpm run shadcn:ui:all",
    "shadcn:ui": "pnpm dlx shadcn@latest add -o -p src/components/ui",
    "shadcn:ui:all": "pnpm dlx shadcn@latest add -a -o -p src/components/ui",
    "shadcn:io": "pnpm dlx shadcn@latest add -o -p src/components/io",
    "shadcn:ui:list": "bash ./scripts/shadcn-ui-list.sh",
    "shadcn:io:list": "bash ./scripts/shadcn-io-list.sh",
    "shadcn:io:backgrounds": "bash ./scripts/shadcn-io-backgrounds.sh",
    "shadcn:io:hooks": "bash ./scripts/shadcn-io-hooks.sh"
  },
  "dependencies": {
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-dropzone": "^15.0.0",
    "react-fast-marquee": "^1.6.5",
    "react-image-crop": "^11.0.10",
    "react-medium-image-zoom": "^5.4.1",
    "react-resizable-panels": "^4.7.3",
    "react-shaders": "^0.0.4",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "react-use-measure": "^2.1.7",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "shiki": "^4.0.2",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
