{
  "name": "gorth-ui",
  "version": "0.0.0",
  "description": "Shared shadcn-based UI package",
  "type": "module",
  "main": "./.ui/index.cjs",
  "module": "./.ui/index.js",
  "types": "./.ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./.ui/index.d.ts",
      "import": "./.ui/index.js",
      "require": "./.ui/index.cjs"
    },
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": {
      "types": "./.ui/lib/*.d.ts",
      "import": "./.ui/lib/*.js",
      "require": "./.ui/lib/*.cjs"
    },
    "./components/*": {
      "types": "./.ui/components/*.d.ts",
      "import": "./.ui/components/*.js",
      "require": "./.ui/components/*.cjs"
    }
  },
  "files": [
    ".ui",
    "src/styles/globals.css",
    "postcss.config.mjs"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/components/*.tsx src/lib/*.ts --format esm,cjs --dts --out-dir .ui --clean",
    "dev": "tsup src/index.ts src/components/*.tsx src/lib/*.ts --format esm,cjs --dts --out-dir .ui --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build"
  },
  "keywords": [
    "shadcn",
    "ui",
    "react"
  ],
  "author": "Gorthenburg",
  "license": "GORTH",
  "private": true,
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.3",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
