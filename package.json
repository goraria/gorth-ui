{
  "name": "gorth-ui",
  "version": "0.2.8",
  "description": "Shared shadcn-based UI package",
  "type": "module",
  "author": "Gorthenburg",
  "license": "GORTH",
  "private": true,
  "keywords": [
    "gorth",
    "shadcn",
    "ui",
    "react"
  ],
  "main": "./.ui/index.cjs",
  "module": "./.ui/index.js",
  "types": "./.ui/index.d.ts",
  "exports": {
    ".": {
      "types": "./.ui/index.d.ts",
      "import": "./.ui/index.js",
      "require": "./.ui/index.cjs"
    },
    "./cores/lucide": {
      "types": "./.ui/cores/lucide.d.ts",
      "import": "./.ui/cores/lucide.js",
      "require": "./.ui/cores/lucide.cjs"
    },
    "./cores/sonner": {
      "types": "./.ui/cores/sonner.d.ts",
      "import": "./.ui/cores/sonner.js",
      "require": "./.ui/cores/sonner.cjs"
    },
    "./cores/radix": {
      "types": "./.ui/cores/radix.d.ts",
      "import": "./.ui/cores/radix.js",
      "require": "./.ui/cores/radix.cjs"
    },
    "./lib/*": {
      "types": "./.ui/lib/*.d.ts",
      "import": "./.ui/lib/*.js",
      "require": "./.ui/lib/*.cjs"
    },
    "./default/*": {
      "types": "./.ui/components/ui/*.d.ts",
      "import": "./.ui/components/ui/*.js",
      "require": "./.ui/components/ui/*.cjs"
    },
    "./pattern/*": {
      "types": "./.ui/components/io/*.d.ts",
      "import": "./.ui/components/io/*.js",
      "require": "./.ui/components/io/*.cjs"
    },
    "./layout/*": {
      "types": "./.ui/components/layout/*.d.ts",
      "import": "./.ui/components/layout/*.js",
      "require": "./.ui/components/layout/*.cjs"
    },
    "./block/*": {
      "types": "./.ui/components/block/*.d.ts",
      "import": "./.ui/components/block/*.js",
      "require": "./.ui/components/block/*.cjs"
    },
    "./custom/*": {
      "types": "./.ui/components/custom/*.d.ts",
      "import": "./.ui/components/custom/*.js",
      "require": "./.ui/components/custom/*.cjs"
    },
    "./background/*": {
      "types": "./.ui/components/background/*.d.ts",
      "import": "./.ui/components/background/*.js",
      "require": "./.ui/components/background/*.cjs"
    },
    "./provider/*": {
      "types": "./.ui/components/provider/*.d.ts",
      "import": "./.ui/components/provider/*.js",
      "require": "./.ui/components/provider/*.cjs"
    },
    "./element/*": {
      "types": "./.ui/components/element/*.d.ts",
      "import": "./.ui/components/element/*.js",
      "require": "./.ui/components/element/*.cjs"
    },
    "./dashboard/*": {
      "types": "./.ui/components/dashboard/*.d.ts",
      "import": "./.ui/components/dashboard/*.js",
      "require": "./.ui/components/dashboard/*.cjs"
    },
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs"
  },
  "files": [
    ".ui",
    "src/styles/globals.css",
    "postcss.config.mjs"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/lucide.ts src/components/*/*.tsx src/hooks/*.ts src/hooks/*.tsx src/lib/*.ts src/cores/*.ts --format esm,cjs --dts --out-dir .ui --clean",
    "dev": "tsup src/index.ts src/lucide.ts src/components/*/*.tsx src/hooks/*.ts src/hooks/*.tsx src/lib/*.ts src/cores/*.ts --format esm,cjs --dts --out-dir .ui --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "update": "pnpm update",
    "shadcn": "pnpm run shadcn:ui:all",
    "shadcn:ui": "pnpm dlx shadcn@latest add -o -p src/components/ui",
    "shadcn:ui:all": "pnpm dlx shadcn@latest add -a -o -p src/components/ui",
    "shadcn:io": "pnpm dlx shadcn@latest add -o -p src/components/io",
    "shadcn:ui:list": "bash ./scripts/shadcn-ui-list.sh",
    "shadcn:io:list": "bash ./scripts/shadcn-io-list.sh",
    "shadcn:io:backgrounds": "bash ./scripts/shadcn-io-backgrounds.sh",
    "shadcn:io:hooks": "bash ./scripts/shadcn-io-hooks.sh"
  },
  "dependencies": {
    "ai": "^6.0.142",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-dropzone": "^15.0.0",
    "react-fast-marquee": "^1.6.5",
    "react-image-crop": "^11.0.10",
    "react-medium-image-zoom": "^5.4.1",
    "react-resizable-panels": "^4.8.0",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "react-use-measure": "^2.1.7",
    "recharts": "3.8.1",
    "shadcn": "^4.1.1",
    "shiki": "^4.0.2",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
