{
  "name": "gorth-ui",
  "version": "1.0.0",
  "description": "Shared shadcn-based UI package",
  "type": "module",
  "author": "Gorthenburg",
  "license": "GORTH",
  "private": true,
  "keywords": [
    "gorth",
    "shadcn",
    "ui",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goraria/gorth-ui.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/globals.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cores/lucide": {
      "types": "./dist/cores/lucide.d.ts",
      "import": "./dist/cores/lucide.js"
    },
    "./cores/sonner": {
      "types": "./dist/cores/sonner.d.ts",
      "import": "./dist/cores/sonner.js"
    },
    "./cores/radix": {
      "types": "./dist/cores/radix.d.ts",
      "import": "./dist/cores/radix.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./default/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.js"
    },
    "./pattern/*": {
      "types": "./dist/components/io/*.d.ts",
      "import": "./dist/components/io/*.js"
    },
    "./layout/*": {
      "types": "./dist/components/layout/*.d.ts",
      "import": "./dist/components/layout/*.js"
    },
    "./block/*": {
      "types": "./dist/components/block/*.d.ts",
      "import": "./dist/components/block/*.js"
    },
    "./custom/*": {
      "types": "./dist/components/custom/*.d.ts",
      "import": "./dist/components/custom/*.js"
    },
    "./background/*": {
      "types": "./dist/components/background/*.d.ts",
      "import": "./dist/components/background/*.js"
    },
    "./provider/*": {
      "types": "./dist/components/provider/*.d.ts",
      "import": "./dist/components/provider/*.js"
    },
    "./element/*": {
      "types": "./dist/components/element/*.d.ts",
      "import": "./dist/components/element/*.js"
    },
    "./dashboard/*": {
      "types": "./dist/components/dashboard/*.d.ts",
      "import": "./dist/components/dashboard/*.js"
    },
    "./globals.css": "./dist/globals.css",
    "./postcss.config": "./postcss.config.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && pnpm exec tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css --minify",
    "dev": "tsup --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm build",
    "update": "pnpm update",
    "shadcn": "pnpm dlx shadcn@latest add -a -o",
    "shadcn:ui": "pnpm dlx shadcn@latest add -o -p src/components/ui",
    "shadcn:ui:all": "pnpm dlx shadcn@latest add -a -o -p src/components/ui",
    "shadcn:io": "pnpm dlx shadcn@latest add -o -p src/components/io",
    "shadcn:ui:list": "bash ./scripts/shadcn-ui-list.sh",
    "shadcn:io:list": "bash ./scripts/shadcn-io-list.sh",
    "shadcn:io:backgrounds": "bash ./scripts/shadcn-io-backgrounds.sh",
    "shadcn:io:hooks": "bash ./scripts/shadcn-io-hooks.sh"
  },
  "dependencies": {
    "ai": "^6.0.142",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "fs-extra": "^11.3.4",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-dropzone": "^15.0.0",
    "react-fast-marquee": "^1.6.5",
    "react-image-crop": "^11.0.10",
    "react-medium-image-zoom": "^5.4.1",
    "react-resizable-panels": "^4.8.0",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "react-use-measure": "^2.1.7",
    "recharts": "3.8.1",
    "shadcn": "^4.1.2",
    "shiki": "^4.0.2",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
